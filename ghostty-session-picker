#!/usr/bin/env bash
# ghostty-session-picker: fzf-based session picker for Ghostty startup
# https://github.com/coa00/ghostty-session-picker

set -euo pipefail

ZELLIJ_BIN="${ZELLIJ_BIN:-$(command -v zellij 2>/dev/null || echo "")}"
TMUX_BIN="${TMUX_BIN:-$(command -v tmux 2>/dev/null || echo "")}"
FZF_BIN="${FZF_BIN:-$(command -v fzf 2>/dev/null || echo "")}"
LOG_FILE="${GHOSTTY_SESSION_PICKER_LOG:-$HOME/.local/share/ghostty-session-picker.log}"

if [ -z "$FZF_BIN" ]; then
  echo "Error: fzf is required. Install it with: brew install fzf" >&2
  exec "$SHELL"
fi

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') [$$] $*" >> "$LOG_FILE"
}

# Restore last working directory
cd_to_last_dir() {
  local dir=""
  if [ -n "${TMUX:-}" ] && [ -n "$TMUX_BIN" ]; then
    dir=$("$TMUX_BIN" display-message -p -t '{last}' '#{pane_current_path}' 2>/dev/null || true)
  fi
  if [ -z "$dir" ] && [ -f "$HOME/.last_working_dir" ]; then
    dir=$(cat "$HOME/.last_working_dir")
  fi
  if [ -n "$dir" ] && [ -d "$dir" ]; then
    log "cd to last dir: $dir"
    cd "$dir"
  fi
}

# Build the selection list
choices=""

# Existing zellij sessions
if [ -n "$ZELLIJ_BIN" ]; then
  zellij_sessions=$("$ZELLIJ_BIN" list-sessions --no-formatting --short 2>/dev/null || true)
  if [ -n "$zellij_sessions" ]; then
    choices=$(echo "$zellij_sessions" | sed 's/^/[zellij] /')
  fi
fi

# Existing tmux sessions
if [ -n "$TMUX_BIN" ]; then
  tmux_sessions=$("$TMUX_BIN" list-sessions -F "#{session_name}" 2>/dev/null || true)
  if [ -n "$tmux_sessions" ]; then
    tmux_items=$(echo "$tmux_sessions" | sed 's/^/[tmux] /')
    if [ -n "$choices" ]; then
      choices="$choices\n$tmux_items"
    else
      choices="$tmux_items"
    fi
  fi
fi

# New session options
new_options="[new] Ghostty (plain shell)"
[ -n "$TMUX_BIN" ] && new_options="$new_options\n[new] tmux"
[ -n "$ZELLIJ_BIN" ] && new_options="$new_options\n[new] zellij"

if [ -n "$choices" ]; then
  choices="$new_options\n$choices"
else
  choices="$new_options"
fi

# Show fzf picker
selected=$(echo -e "$choices" | "$FZF_BIN" \
  --height=~50% \
  --layout=reverse \
  --border=rounded \
  --prompt="session > " \
  --header="Select a session or create new" \
  --no-info \
  --color=pointer:green,prompt:blue,header:dim) || {
  # If fzf is cancelled (Esc/Ctrl-C), start plain shell
  exec "$SHELL"
}

log "selected: $selected"

case "$selected" in
  "[new] Ghostty (plain shell)")
    log "launching plain shell"
    cd_to_last_dir
    exec "$SHELL"
    ;;
  "[new] zellij")
    printf "Session name (empty for default): " > /dev/tty
    read -r session_name < /dev/tty
    cd_to_last_dir
    if [ -z "$session_name" ]; then
      log "launching new zellij (default name)"
      exec "$ZELLIJ_BIN"
    else
      log "launching new zellij: $session_name"
      exec "$ZELLIJ_BIN" -s "$session_name"
    fi
    ;;
  "[new] tmux")
    log "launching new tmux: ghostty-$$"
    cd_to_last_dir
    set +e
    "$TMUX_BIN" new-session -s "ghostty-$$" 2>>"$LOG_FILE"
    rc=$?
    log "tmux new-session exited with code $rc"
    exec "$SHELL"
    ;;
  \[tmux\]\ *)
    session_name="${selected#\[tmux\] }"
    log "attaching tmux: $session_name"
    set +e
    "$TMUX_BIN" attach-session -t "$session_name" 2>>"$LOG_FILE"
    rc=$?
    log "tmux attach exited with code $rc"
    exec "$SHELL"
    ;;
  \[zellij\]\ *)
    session_name="${selected#\[zellij\] }"
    log "attaching zellij: $session_name"
    exec "$ZELLIJ_BIN" attach "$session_name"
    ;;
  *)
    log "unknown selection: $selected"
    exec "$SHELL"
    ;;
esac
